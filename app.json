{
  "expo": {
    "name": "TOORI Servicios Ya",
    "slug": "appTrabajo",
    "scheme": "solucionesya",
    "linking": {
      "prefixes": ["solucionesya://"],
      "config": {
        "screens": {
          "pago-exitoso": "pago-exitoso"
        }
      }
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "version": "87.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "assets/icon.png",
      "assets/splash-icon.png",
      "assets/adaptive-icon.png",
      "assets/favicon.png"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "ios": {
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Esta app utiliza tu ubicación para mostrar trabajadores o proveedores de servicios cercanos, como plomeros o electricistas, y ayudarte a recibir asistencia más rápido y eficiente en tu zona.",
        "NSUserNotificationsUsageDescription": "Esta app necesita enviarte notificaciones para alertarte cuando recibas un mensaje nuevo o cuando tu servicio haya sido contratado, manteniéndote informado sobre las actualizaciones importantes.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "solucionesya",
              "com.googleusercontent.apps.453761258131-6anu4ghpi4jv1df72490vo69vj23qq22"
            ]
          }
        ],
        "LSApplicationQueriesSchemes": ["whatsapp"]
      },
      "bundleIdentifier": "com.alex-6775.appTrabajo",
      "appleTeamId": "HHY5MJ22J3",
      "associatedDomains": ["applinks:inicio.serviciosya.info"]
    },
    "android": {
      "versionCode": 87,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "statusBar": {
        "backgroundColor": "#069eb3",
        "barStyle": "light-content",
        "translucent": false
      },
      "edgeToEdgeEnabled": true,
      "package": "com.alex_6775.appTrabajo",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "inicio.serviciosya.info",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "solucionesya"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      "expo-apple-authentication",
      "@maplibre/maplibre-react-native",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.453761258131-6anu4ghpi4jv1df72490vo69vj23qq22"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fff",
          "image": "./assets/splash-icon.png",
          "imageWidth": 150
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que $(PRODUCT_NAME) acceda a tu ubicación en todo momento para mostrarte trabajadores o proveedores de servicios cercanos y ayudarte a recibir asistencia más rápida y eficiente en tu zona."
        }
      ],
      "react-native-edge-to-edge",
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Permitir que $(PRODUCT_NAME) utiliza tu ubicación para mostrar trabajadores o proveedores de servicios cercanos, como plomeros o electricistas, y ayudarte a recibir asistencia más rápido y eficiente en tu zona."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acceso a tu galería para subir imágenes en la aplicación.",
          "cameraPermission": "Esta app necesita acceder a tu cámara exclusivamente para tomar una foto de tu cara y usarla como foto de perfil dentro de la aplicación."
        }
      ],
      "expo-av",
      "expo-web-browser",
      "expo-asset"
    ],
    "extra": {
      "tooriSyncBaseUrl": "https://tooriserviciosya.com",
      "tooriAppSyncToken": "",
      "eas": {
        "projectId": "aea4aff9-1e66-4a9c-a2e7-17402b7bc1f1"
      },
      "router": {
        "entry": "./expo-router-entry.js"
      }
    },
    "owner": "perezzz2003"
  }
}
