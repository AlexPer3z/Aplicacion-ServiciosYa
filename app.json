{
  "expo": {
    "name": "Servicios Ya",
    "slug": "appTrabajo",
    "scheme": "solucionesya",
    "linking": {
      "prefixes": [
        "solucionesya://"
      ],
      "config": {
        "screens": {
          "pago-exitoso": "pago-exitoso"
        }
      }
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "version": "12.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "assets/icon.png",
      "assets/splash-icon.png",
      "assets/adaptive-icon.png",
      "assets/favicon.png"
    ],
    "ios": {
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos tu ubicación para mostrar trabajadores cercanos y ayudarte a recibir el servicio más rápido posible.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "solucionesya",
              "com.googleusercontent.apps.453761258131-6anu4ghpi4jv1df72490vo69vj23qq22"
            ]
          }
        ],
        "LSApplicationQueriesSchemes": ["whatsapp"]
      },
      "bundleIdentifier": "com.alex-6775.appTrabajo",
      "appleTeamId": "HHY5MJ22J3"
    },
    "android": {
      "versionCode": 12,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.alex_6775.appTrabajo",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      "expo-apple-authentication",
      "@maplibre/maplibre-react-native",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.453761258131-6anu4ghpi4jv1df72490vo69vj23qq22"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fff",
          "image": "./assets/splash-icon.png",
          "imageWidth": 150
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que $(PRODUCT_NAME) utilice su ubicación."
        }
      ],
      "react-native-edge-to-edge",
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Allow $(PRODUCT_NAME) to use your location"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "aea4aff9-1e66-4a9c-a2e7-17402b7bc1f1"
      }
    },
    "owner": "perezzz2003"
  }
}
